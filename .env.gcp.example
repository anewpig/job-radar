# GCP VM deployment baseline
# Copy this file to .env on the VM and fill in the secrets before starting docker compose.

JOB_RADAR_DATA_VOLUME=/srv/job-radar-data
JOB_RADAR_DEPLOY_ENV=docker
JOB_RADAR_RELEASE_CHANNEL=prod

JOB_SPY_DATA_DIR=/app/data
JOB_SPY_CRAWL_EXECUTION_MODE=worker
JOB_SPY_LOG_FORMAT=json
JOB_SPY_LOG_DIR=/app/data/logs

JOB_SPY_LOCATION=台灣
JOB_SPY_REQUEST_TIMEOUT=20
JOB_SPY_REQUEST_DELAY=1.0
JOB_SPY_MAX_CONCURRENT_REQUESTS=4
JOB_SPY_MAX_PAGES_PER_SOURCE=1
JOB_SPY_MAX_DETAIL_JOBS_PER_SOURCE=0

JOB_SPY_SNAPSHOT_TTL_SECONDS=1800
JOB_SPY_SEARCH_CACHE_TTL_SECONDS=1800
JOB_SPY_DETAIL_CACHE_TTL_SECONDS=43200
JOB_SPY_CACHE_MAX_BYTES=256000000
JOB_SPY_CACHE_MAX_FILES=4000
JOB_SPY_CACHE_BACKEND=filesystem
JOB_SPY_QUEUE_BACKEND=sqlite
JOB_SPY_DATABASE_BACKEND=sqlite

JOB_SPY_CRAWL_JOB_LEASE_SECONDS=180
JOB_SPY_ENABLE_BACKEND_CONSOLE=false
JOB_RADAR_BACKEND_CONSOLE_ALLOWED_ROLES=operator,admin
JOB_SPY_RUNTIME_JOB_MAX_RETRIES=1
JOB_SPY_RUNTIME_JOB_RETRY_BACKOFF_SECONDS=90
JOB_SPY_RUNTIME_CLEANUP_INTERVAL_SECONDS=21600
JOB_SPY_RUNTIME_JOB_RETENTION_DAYS=14
JOB_SPY_RUNTIME_SNAPSHOT_RETENTION_DAYS=30
JOB_SPY_RUNTIME_PARTIAL_SNAPSHOT_RETENTION_HOURS=12
JOB_SPY_RUNTIME_SIGNAL_RETENTION_DAYS=14
JOB_SPY_MARKET_HISTORY_RETENTION_DAYS=90
JOB_SPY_MARKET_HISTORY_MAX_RUNS_PER_QUERY=100

JOB_SPY_GLOBAL_SEARCH_ENABLED=true
JOB_SPY_GLOBAL_SAVED_SEARCH_NAME=系統定期追蹤
JOB_SPY_GLOBAL_SEARCH_KEYWORDS=ai工程師,ai應用工程師,軟體工程師,應用工程師,PM,ai架構師,資料科學家,軟韌體工程師
JOB_SPY_GLOBAL_SEARCH_FREQUENCY_DAYS=2
JOB_SPY_GLOBAL_SEARCH_PRESET=平衡
JOB_SPY_GLOBAL_SEARCH_FORCE_REFRESH=true
JOB_SPY_GLOBAL_SEARCH_USER_EMAIL=system@job-radar.local
JOB_SPY_LINKEDIN_COOLDOWN_SECONDS=1800

JOB_SPY_SQLITE_BACKUP_KEEP_LAST=14
JOB_SPY_SQLITE_BACKUP_INCLUDE_RUNTIME=false
JOB_SPY_BACKEND_MAINTENANCE_FORCE_CLEANUP=true

OPENAI_API_KEY=
OPENAI_BASE_URL=
JOB_SPY_LLM_MODEL=gpt-4.1-mini
JOB_SPY_TITLE_MODEL=gpt-4.1-mini
JOB_SPY_EMBEDDING_MODEL=text-embedding-3-large
JOB_SPY_ASSISTANT_MODEL=gpt-4.1-mini
JOB_SPY_ASSISTANT_GENERAL_CHAT_MODEL=gpt-4.1-mini
JOB_SPY_ASSISTANT_PROMPT_VARIANT=control
JOB_SPY_ASSISTANT_ANN_SYNC_INTERVAL_SECONDS=900
JOB_SPY_ASSISTANT_PERSISTENT_INDEX_ENABLED=false
JOB_SPY_ASSISTANT_PERSISTENT_INDEX_SOURCES=snapshot_file
JOB_SPY_ASSISTANT_PERSISTENT_INDEX_MAX_SNAPSHOTS=1
JOB_SPY_ASSISTANT_PERSISTENT_INDEX_MAX_HISTORY_ROWS=500
JOB_SPY_ASSISTANT_EXTERNAL_SEARCH_ENABLED=false
JOB_SPY_ASSISTANT_EXTERNAL_SEARCH_PROVIDER=duckduckgo
JOB_SPY_ASSISTANT_EXTERNAL_SEARCH_MAX_RESULTS=3
JOB_SPY_ASSISTANT_EXTERNAL_SEARCH_TIMEOUT_SECONDS=4.0
JOB_SPY_ASSISTANT_EXTERNAL_SEARCH_CACHE_TTL_SECONDS=900

JOB_RADAR_PUBLIC_BASE_URL=http://YOUR_STATIC_IP:8501

JOB_RADAR_OIDC_REDIRECT_URI=
JOB_RADAR_OIDC_COOKIE_SECRET=
JOB_RADAR_GOOGLE_CLIENT_ID=
JOB_RADAR_GOOGLE_CLIENT_SECRET=
JOB_RADAR_GOOGLE_SERVER_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
JOB_RADAR_FACEBOOK_CLIENT_ID=
JOB_RADAR_FACEBOOK_CLIENT_SECRET=
JOB_RADAR_FACEBOOK_SERVER_METADATA_URL=

JOB_RADAR_AUTH_COOKIE_SECRET=
JOB_RADAR_AUTH_TOKEN_SECRET=
JOB_RADAR_AUTH_TOKEN_TTL_SECONDS=259200

JOB_RADAR_SMTP_HOST=
JOB_RADAR_SMTP_PORT=587
JOB_RADAR_SMTP_USERNAME=
JOB_RADAR_SMTP_PASSWORD=
JOB_RADAR_SMTP_FROM=
JOB_RADAR_NOTIFY_EMAIL_TO=
JOB_RADAR_SMTP_USE_TLS=true
JOB_RADAR_SMTP_USE_SSL=false

JOB_RADAR_LINE_CHANNEL_ACCESS_TOKEN=
JOB_RADAR_LINE_CHANNEL_SECRET=
JOB_RADAR_LINE_TO=
JOB_RADAR_LINE_WEBHOOK_HOST=0.0.0.0
JOB_RADAR_LINE_WEBHOOK_PORT=8787
